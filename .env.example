
# =============================================================================
# .env.example
# Plantilla de variables de entorno del proyecto.
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.
# =============================================================================

# AWS
AWS_REGION=eu-west-1
AWS_PROFILE=yt_mp3_api_dev

# S3
S3_BUCKET=yt-mp3-api-dev-bucket

# ECS/Fargate
ECS_CLUSTER=yt-mp3-api-cluster
TASK_DEFINITION=yt-mp3-api-worker
SUBNET_ID=subnet-xxxxxxxxxx
SECURITY_GROUP_ID=sg-xxxxxxxxxx

# Worker
AUDIO_QUALITY=2

